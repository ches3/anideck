{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "~/*": ["./app/*"]
    },
    "rootDirs": [".react-router/types/app", "app"],
    "skipLibCheck": true,
    "strict": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    ".react-router/types/**/*",
    "react-router.config.ts",
    "vite.config.ts"
  ]
}
